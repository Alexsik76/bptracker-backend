POSTGRES_PASSWORD=change_me
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
CORS_ORIGINS=https://bptracker.home.vn.ua
FIDO2_DOMAIN=bptracker.home.vn.ua
ASPNETCORE_ENVIRONMENT=Production

# SMTP (Phase 3)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=app_password_here
SMTP_FROM=your@gmail.com
SMTP_FROM_NAME=BP Tracker
SMTP_TLS=true

# Frontend URL for magic-link emails (no trailing slash)
APP_URL=https://bptracker.home.vn.ua

# Comma-separated list of permitted emails (leave empty to deny all)
ALLOWED_EMAILS=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Comma-separated extra origins accepted for native (Android) passkey assertions,
# e.g. android:apk-key-hash:<base64url-sha256-of-signing-cert>
FIDO2_ANDROID_ORIGINS=
